{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "@vercel/php"
    },
    "pages/*.php": {
      "runtime": "@vercel/php"
    },
    "api/*.php": {
      "runtime": "@vercel/php"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/pages/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    }
  ]
}