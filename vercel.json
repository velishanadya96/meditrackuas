{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "pages/*.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/login", "dest": "/login.php" },
    { "src": "/register", "dest": "/register.php" },
    { "src": "/logout", "dest": "/logout.php" },
    { "src": "/konsultasi", "dest": "/konsultasi.php" },
    { "src": "/dashboard", "dest": "/dashboarduser.php" },
    { "src": "/dashboard/(.*)", "dest": "/dashboarduser.php?page=$1" },
    { "src": "/admin", "dest": "/dashboard_admin.php" },
    { "src": "/(.*\\.php)", "dest": "/$1" }
  ]
}